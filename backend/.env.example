DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
JWT_SECRET="troque-por-uma-chave-grande"
FRONTEND_URL="http://localhost:5173"
PORT=4000

# Futuro upload persistente:
# SUPABASE_URL="https://xxxx.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"
# SUPABASE_STORAGE_BUCKET="documents"

# WhatsApp Business Cloud API (Meta) — preencha quando tiver a conta configurada.
# Sem essas variáveis, a Caixa de Entrada funciona normalmente para testes locais,
# mas o envio de mensagens reais fica desabilitado.
# WHATSAPP_ACCESS_TOKEN="token-de-acesso-permanente-da-meta"
# WHATSAPP_PHONE_NUMBER_ID="id-do-numero-de-telefone"
# WHATSAPP_VERIFY_TOKEN="escolha-uma-string-secreta-para-o-webhook"

# Radar e-CAC — o certificado digital (e-CNPJ A1) agora é enviado pela
# própria tela de Configurações > Escritório e fica guardado, criptografado,
# no banco de dados. CERT_ENCRYPTION_KEY é a chave usada para essa
# criptografia (AES-256-GCM) — gere uma string aleatória grande e nunca a
# troque depois de já ter certificados salvos (perderia o acesso a eles).
# CERT_ENCRYPTION_KEY="gere-uma-string-aleatoria-grande-e-unica"
# ECAC_HEADLESS="true"
