# WhatsApp Business Cloud API (Meta) — preencha quando tiver a conta configurada.
# Sem essas variáveis, a Caixa de Entrada funciona normalmente para testes locais,
# mas o envio de mensagens reais fica desabilitado.
# WHATSAPP_ACCESS_TOKEN="token-de-acesso-permanente-da-meta"
# WHATSAPP_PHONE_NUMBER_ID="id-do-numero-de-telefone"
# WHATSAPP_VERIFY_TOKEN="escolha-uma-string-secreta-para-o-webhook"
